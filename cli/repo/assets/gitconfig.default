[merge "sesam-merge"]
  name = "merge the audit log of sesam"
  driver = "sesam audit merge %O %A %B %L %P"

[diff "sesam-diff"]
  # called to convert .age files to plaintext for the purpose of diffing
  textconv = "sesam show"
  cachetextconv = true

[filter "sesam-filter"]
  # called when checkout out a specific version of a file
  smudge = cat %f
  # called when checking in a file (i.e. git add)
  clean = cat %f
