{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/open-sesam/sesam/",
  "title": "Sesam Schema",
  "description": "Sesam's config file (containing user/groups and secret definitions)",
  "$defs": {
    "pubkey": {
      "type": "string",
      "description": "Public key of this user, either as literal, forge-id, file path or link"
    },
    "non-empty-string": {
      "type": "string",
      "minLength": 1
    }
  },
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {
      "x-order": 0,
      "description": "The version of this config file format.",
      "type": "integer",
      "default": 1,
      "minimum": 1,
      "maximum": 1
    },
    "users": {
      "x-order": 1,
      "description": "List of users known to this repository.",
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "key"
        ],
        "properties": {
          "name": {
            "x-order": 0,
            "$ref": "#/$defs/non-empty-string",
            "description": "Name of a user"
          },
          "key": {
            "x-order": 1,
            "description": "Public key(s) of this user. May be given once or several times.",
            "anyOf": [
              {
                "$ref": "#/$defs/pubkey"
              },
              {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/pubkey"
                }
              }
            ]
          },
          "desc": {
            "x-order": 2,
            "$ref": "#/$defs/non-empty-string",
            "description": "Description or full name of this user"
          }
        }
      }
    },
    "groups": {
      "x-order": 2,
      "description": "Named groups of users. Each key is a group name mapped to a list of user names from the users list.",
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/non-empty-string",
          "description": "One of the names described in users above"
        }
      }
    },
    "secrets": {
      "x-order": 3,
      "description": "List of secret definitions and sub-file includes.",
      "type": "array",
      "items": {
        "oneOf": [
          {
            "description": "Include form — delegates to a subordinate sesam.yml in a sub-directory",
            "type": "object",
            "additionalProperties": false,
            "required": [
              "include"
            ],
            "properties": {
              "include": {
                "$ref": "#/$defs/non-empty-string",
                "description": "Path to a subordinate sesam.yml file"
              }
            }
          },
          {
            "description": "Secret form — registers a file as a managed secret",
            "type": "object",
            "additionalProperties": false,
            "required": [
              "path"
            ],
            "properties": {
              "path": {
                "$ref": "#/$defs/non-empty-string",
                "description": "Path to the decrypted secret"
              },
              "access": {
                "type": "array",
                "description": "Groups or users allowed to reveal this secret. Defaults to admin only when omitted.",
                "items": {
                  "$ref": "#/$defs/non-empty-string"
                }
              },
              "desc": {
                "$ref": "#/$defs/non-empty-string",
                "description": "Description of the secret"
              }
            }
          }
        ]
      }
    }
  }
}
